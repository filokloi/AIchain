#!/usr/bin/env sh
MSG_FILE="$1"
MSG=$(sed -e 's/^\s*//' -e 's/\s*$//' "$MSG_FILE")

PATTERN='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-zA-Z0-9._-]+\))?: .+'

if printf "%s" "$MSG" | grep -Eq "$PATTERN"; then
  exit 0
fi

echo "ERROR: Commit message must follow Conventional Commits." >&2
echo "Expected: <type>(<scope>): <message> or <type>: <message>" >&2
echo "Allowed types: feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert" >&2
exit 1
