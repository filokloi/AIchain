#!/usr/bin/env sh

# Block common runtime artifacts
if git diff --cached --name-only | grep -E '(proxy_debug\.log|stderr_output\.txt|\.log$|\.tmp$|\.pid$)' >/dev/null 2>&1; then
  echo "ERROR: Runtime/log artifacts are staged. Remove them before commit." >&2
  exit 1
fi

# Basic secret pattern guard
if git diff --cached | grep -E '(sk-or-v1-|sk-proj-|AIza[0-9A-Za-z_-]{20,}|xoxb-[0-9A-Za-z-]+)' >/dev/null 2>&1; then
  echo "ERROR: Potential secret detected in staged diff." >&2
  echo "Review and remove secrets before committing." >&2
  exit 1
fi

exit 0
